# MIDTRANS PAYMENT GATEWAY CONFIGURATION
# Get your keys from: https://dashboard.midtrans.com

# ========== SANDBOX MODE (Development) ==========
# These keys are for testing. Replace with your actual Midtrans credentials.

# Server Key - Keep this SECRET, only use on server-side
MIDTRANS_SERVER_KEY=Mid-server-YOUR_SANDBOX_SERVER_KEY_HERE
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-YOUR_SANDBOX_CLIENT_KEY_HERE

# ========== PRODUCTION MODE (When Ready) ==========
# Uncomment and replace these when deploying to production
# MIDTRANS_SERVER_KEY=Mid-server-YOUR_ACTUAL_PRODUCTION_SERVER_KEY
# NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=Mid-client-YOUR_ACTUAL_PRODUCTION_CLIENT_KEY

# ========== OTHER CONFIGURATION ==========
# Set to true for production, false for sandbox
NEXT_PUBLIC_MIDTRANS_PRODUCTION=true
