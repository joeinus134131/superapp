{
  "name": "superapp-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "SuperApp - Monorepo (Web + Mobile + Shared)",
  "scripts": {
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@superapp/web",
    "dev:mobile": "turbo run dev --filter=@superapp/mobile",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@superapp/web",
    "build:mobile": "turbo run build --filter=@superapp/mobile",
    "lint": "turbo run lint",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react": "18 || 19",
        "react-dom": "18 || 19"
      },
      "ignoreMissing": [
        "babel-plugin-react-compiler"
      ]
    }
  }
}
